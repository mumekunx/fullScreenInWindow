{
  "manifest_version": 3,
  "name": "Window Fullscreen",
  "version": "1.1.0",
  "description": "ユーザーが明示的に有効化したタブで、サイトのフルスクリーン操作をウィンドウ内表示に切り替えます。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Window Fullscreen"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
